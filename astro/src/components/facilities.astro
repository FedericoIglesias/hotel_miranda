</script>

<style define:vars={{ bg1, bg2, color, header }}>
  section {
    display: flex;
    justify-content: center;
    flex-direction: column;
    align-items: center;
    padding: 40px 0;
    color: var(--color);
    background-color: var(--bg1);
    header {
      text-align: center;
      font-family: sans-serif;
      font-size: 14px;
      letter-spacing: 2px;
      color: var(--header);
      font-weight: bold;
      padding: 10px 0;
    }
    h3 {
      font-size: 56px;
      font-family: serif;
      text-align: center;
      font-weight: 50;
      padding: 20px 0;
    }
    article {
      background-color: var(--bg2);
    }
    /* div {
      display: flex;
      align-items: center;
      justify-content: center;

      flex-wrap: wrap;
    } */
  }
  @media screen and (min-width: 1024px) {
    section {
      h3 {
        font-size: 96px;
      }
      /* div {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 50px;
      } */
    }
  }
</style>

